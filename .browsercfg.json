{
  "remote": {
    "run_on": ["import"],
    "init": [["git_clone", "https://github.com/sineorg/bootloader.git", "bootloader"]],
    "update": [
      ["cd", "bootloader"],
      ["git_pull", "origin", "main"]
    ]
  },
  "import": {
    "scripts": {
      "init": [["py_exec", "scripts/extract_update.py"]],
      "cleanup": [["rm", "engine.tmp.json"]]
    },
    "files": {
      "{remote}/bootloader/program": "{browser}",
      "{remote}/bootloader/profile/utils": "{profile}/chrome/utils",
      "src": "{profile}/chrome/JS",
      "locales": "{profile}/chrome/JS/locales",
      "engine.tmp.json": "{profile}/chrome/JS/engine.json",
      "tests": "{profile}/chrome/tests"
    }
  },
  "test": {}
}
